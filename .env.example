# ─────────────────────────────────────────────
#  This file documents every environment variable
#  needed to run the project. Copy the relevant
#  sections into:
#    apps/api/.env
#    apps/web/.env.local
#  Never commit real values to git.
# ─────────────────────────────────────────────


# ── apps/api/.env ─────────────────────────────

# Port the API listens on (optional, defaults to 3001)
PORT=3001

# SQLite for local dev — swap to a postgres:// URL for production
DATABASE_URL="file:./dev.db"

# 32-byte hex key for encrypting stored credentials at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your-64-char-hex-key-here"

# Redis connection string — get a free instance at upstash.com or use Railway Redis
REDIS_URL="rediss://default:xxxx@xxxx.upstash.io:6379"

# Threads OAuth — create an app at developers.facebook.com → Threads use case
THREADS_APP_ID="your-threads-app-id"
THREADS_APP_SECRET="your-threads-app-secret"
# Must match exactly what you set in the Meta dashboard callback URL field
THREADS_REDIRECT_URI="https://your-domain.com/auth/threads/callback"

# Public HTTPS URL of this API — Meta fetches uploaded images from here
# In dev: use a tunnel (e.g. VS Code port forwarding). In prod: your real domain.
PUBLIC_API_URL="https://your-domain.com"


# ── apps/web/.env.local ───────────────────────

# URL of the API server as seen from the browser
NEXT_PUBLIC_API_URL=http://localhost:3001

# Full URL of the Threads OAuth start route on your API
# In dev: your tunnel URL. In prod: https://your-api-domain.com/auth/threads
NEXT_PUBLIC_THREADS_AUTH_URL=https://your-domain.com/auth/threads
