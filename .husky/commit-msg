#!/bin/sh
MSG=$(cat "$1")
PATTERN='^(feat|fix|docs|chore|refactor|style|test|perf|ci|build|revert)(\(.+\))?(!)?: .{1,100}'
if ! echo "$MSG" | grep -qE "$PATTERN"; then
  echo ""
  echo "  ✗ Invalid commit message format."
  echo ""
  echo "  Expected: <type>(<scope>): <subject>"
  echo "  Example:  feat(nav): add Pinterest to platforms dropdown"
  echo ""
  echo "  Types: feat | fix | docs | chore | refactor | style | test | perf | ci | build | revert"
  echo ""
  exit 1
fi
