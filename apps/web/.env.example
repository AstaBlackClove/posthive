# URL of the API server — change to your production URL when deploying
NEXT_PUBLIC_API_URL=http://localhost:3001

# Full URL of the Threads OAuth start route on your API.
# In dev: use your tunnel URL (e.g. VS Code port forwarding) so Meta can redirect back.
# In production: https://your-api-domain.com/auth/threads
NEXT_PUBLIC_THREADS_AUTH_URL=https://your-tunnel-or-domain.com/auth/threads
