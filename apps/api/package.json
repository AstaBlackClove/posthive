    "@prisma/client": "^5.16.2",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "node-cron": "^3.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/node-cron": "^3.0.11",
    "prisma": "^5.16.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
