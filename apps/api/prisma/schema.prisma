// Targeting SQLite for local dev, Postgres for production.
// Avoid any SQLite-only features so this schema works with both.
// To switch: change provider to "postgresql" and update DATABASE_URL.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// App user — created via local JWT auth or Supabase (cloud).
// supabaseId is null for local auth users.
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  passwordHash String? // null for Supabase auth users
  supabaseId  String?  @unique // null for local auth users
  avatarUrl   String?
  timezone    String    @default("UTC")

  // Billing
  plan           String    @default("trialing")   // trialing | creator | pro | team | cancelled
  planStatus     String    @default("trialing")   // trialing | active | on_hold | cancelled
  trialEndsAt    DateTime?
  dodoCustomerId String?   @unique
  dodoSubId      String?   @unique

  emailVerified Boolean   @default(false)
  webhookUrl    String?   // outbound webhook fired on post publish

  accounts      Account[]
  postJobs      PostJob[]
  refreshTokens RefreshToken[]
  apiKeys       ApiKey[]
  emailVerifications EmailVerification[]
  templates     Template[]
  sessions      Session[]
  events        Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Stored refresh tokens for local auth — allows revocation on logout.
model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// A connected social media account for a specific platform.
model Account {
  id           String    @id @default(cuid())
  platform     String    // "bluesky" | "threads" | "linkedin"
  displayName  String
  credentials  String    // AES-256-GCM encrypted JSON, never plaintext
  avatarUrl    String?
  refreshToken String?
  expiresAt    DateTime?

  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  targets PostJobTarget[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A scheduled post job.
model PostJob {
  id           String    @id @default(cuid())
  scheduledFor DateTime?
  status       String    @default("pending")
  content      String
  commentText  String?
  dryRun       Boolean  @default(false)

  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  targets PostJobTarget[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// One row per (PostJob × Account).
model PostJobTarget {
  id String @id @default(cuid())

  postJob   PostJob @relation(fields: [postJobId], references: [id], onDelete: Cascade)
  postJobId String

  account   Account @relation(fields: [accountId], references: [id])
  accountId String

  status         String  @default("pending")
  platformPostId String?
  replyContext   String?
  error          String?
  attempts       Int     @default(0)

  stats PostStats?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Cached engagement stats per PostJobTarget — synced every 6h by statsCron.
model PostStats {
  id       String @id @default(cuid())
  targetId String @unique

  target PostJobTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)

  likes    Int  @default(0)
  reposts  Int  @default(0)
  replies  Int  @default(0)
  views    Int?

  fetchedAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([targetId])
}

// Email verification token — single-use, 24-hour TTL.
model EmailVerification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
}

// Password reset token — single-use, 1-hour TTL.
model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
}

// Tracks uploaded media files so orphans can be cleaned up.
model Upload {
  id        String    @id @default(cuid())
  url       String    @unique
  userId    String
  claimedAt DateTime? // set when a PostJob references this file
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([claimedAt, createdAt])
}

// Short-lived nonce for OAuth CSRF protection.
model OAuthState {
  id        String   @id @default(cuid())
  userId    String
  nonce     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([nonce])
}

// API key for programmatic access (Pro/Team plans, or all users when billing disabled).
model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String                      // human label e.g. "My Claude agent"
  keyHash    String    @unique           // SHA-256 hash of the raw key
  prefix     String                      // first 12 chars shown in UI e.g. "ph_abc12345"
  lastUsedAt DateTime?
  revokedAt  DateTime?                   // null = active
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([keyHash])
}

// Saved post template — reusable content for compose.
model Template {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  content   String   // JSON: { text, commentText, mediaUrls, altTexts, mediaType, youtubeType }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Anonymous + pre-login visitor session — one row per browser session.
// Updated as the visitor navigates; flushed on tab close or login.
model Session {
  id        String   @id @default(cuid())
  visitorId String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  entry     String
  exit      String?
  pages     Json
  referrer  String?
  converted Boolean  @default(false)
  duration  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([visitorId])
  @@index([userId])
  @@index([createdAt])
}

model Event {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event      String
  properties Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([event])
  @@index([createdAt])
}

// Cancellation feedback submitted when a user cancels their subscription.
model CancellationFeedback {
  id        String   @id @default(cuid())
  userId    String
  plan      String
  reason    String?
  feedback  String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}
