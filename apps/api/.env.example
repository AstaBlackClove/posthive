PORT=3001

# Sentry error monitoring (optional)
# SENTRY_DSN="https://your-dsn@sentry.io/project-id"
# SENTRY_ENABLED="true"   # set to "true" in dev to test Sentry locally
# Option A — Docker Postgres (recommended): run `pnpm dev:db` from the project root first
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres"

# Option B — SQLite (no Docker needed): change schema.prisma provider to "sqlite" too
# DATABASE_URL="file:./dev.db"

# Set to "true" to enable Dodo Payments billing and plan limits.
# Leave unset or "false" for self-hosted use — all features unlocked, no limits.
ENABLE_BILLING=false

# Auth provider — "local" (default, no extra setup) or "supabase" (cloud)
AUTH_PROVIDER=local

# JWT secrets — generate two separate random strings (local auth only)
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET="your-access-secret-here"
JWT_REFRESH_SECRET="your-refresh-secret-here"

# Web app URL — used for CORS and OAuth redirects
WEB_URL=http://localhost:3000

# Set to "true" in production so auth cookies are sent over HTTPS only
SECURE_COOKIES=false

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: never change this after accounts are saved — credentials become unreadable
ENCRYPTION_KEY="your-64-char-hex-key-here"

# Redis connection string — Upstash or Railway Redis
REDIS_URL="rediss://..."

# ---------------------------------------------------------------------------
# Storage — where uploaded media files are stored
# ---------------------------------------------------------------------------
# "local" (default) stores files on disk under apps/api/uploads/
# "supabase" uploads to Supabase Storage (required for production / multi-instance)
STORAGE_PROVIDER=local

# Supabase Storage (only when STORAGE_PROVIDER=supabase)
# Create a public bucket in the Supabase dashboard first
SUPABASE_STORAGE_BUCKET="media"

# ---------------------------------------------------------------------------
# Supabase (only required when AUTH_PROVIDER=supabase or STORAGE_PROVIDER=supabase)
# ---------------------------------------------------------------------------
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ---------------------------------------------------------------------------
# Email (password reset) — Resend (https://resend.com)
# Optional — falls back to console logging in dev if not set
# ---------------------------------------------------------------------------
RESEND_API_KEY="re_..."
# From address — must be from a domain verified in your Resend account
EMAIL_FROM="Posthive <noreply@yourdomain.com>"

# ---------------------------------------------------------------------------
# OAuth — Threads
# Create an app at developers.facebook.com and add the Threads use case
# ---------------------------------------------------------------------------
THREADS_APP_ID="your-threads-app-id"
THREADS_APP_SECRET="your-threads-app-secret"
THREADS_REDIRECT_URI="https://your-domain.com/auth/threads/callback"

# ---------------------------------------------------------------------------
# OAuth — Instagram
# Add the Instagram product to your Meta app at developers.facebook.com
# Requires a Professional (Business or Creator) Instagram account
# ---------------------------------------------------------------------------
INSTAGRAM_APP_ID="your-instagram-app-id"
INSTAGRAM_APP_SECRET="your-instagram-app-secret"
INSTAGRAM_REDIRECT_URI="https://your-domain.com/auth/instagram/callback"

# Public HTTPS URL of this API — Meta fetches uploaded images from here
# Must be publicly reachable (not localhost). Use a tunnel in dev.
PUBLIC_API_URL="https://your-domain.com"

# ---------------------------------------------------------------------------
# OAuth — LinkedIn
# Create an app at developer.linkedin.com
# Required products: "Share on LinkedIn" + "Sign In with LinkedIn using OpenID Connect"
# ---------------------------------------------------------------------------
LINKEDIN_CLIENT_ID="your-linkedin-client-id"
LINKEDIN_CLIENT_SECRET="your-linkedin-client-secret"
LINKEDIN_REDIRECT_URI="https://your-domain.com/auth/linkedin/callback"

# ---------------------------------------------------------------------------
# Mastodon OAuth
# Create an app at https://your-instance/settings/applications
# ---------------------------------------------------------------------------
MASTODON_CLIENT_ID="your-mastodon-client-id"
MASTODON_CLIENT_SECRET="your-mastodon-client-secret"
MASTODON_REDIRECT_URI="https://your-domain.com/auth/mastodon/callback"

# ---------------------------------------------------------------------------
# OAuth — YouTube
# Create a project + OAuth client at console.cloud.google.com, enable the
# YouTube Data API v3. Add your channel as a test user while the app is
# in "Testing" publishing status (or submit for verification for prod).
#
# IMPORTANT: unlike Threads/Instagram, YouTube does NOT need a public tunnel.
# Google requires the redirect URI's domain to be owned and verified (via
# Search Console) — shared tunnel domains (devtunnels.ms, ngrok.io, etc.)
# can never pass that and will hard-block with "Error 403: access_denied".
# Use http://localhost:<API_PORT>/auth/youtube/callback instead — Google
# exempts localhost from domain verification. This only works when you
# connect YouTube from a browser on the same machine as the API server.
# ---------------------------------------------------------------------------
YOUTUBE_CLIENT_ID="your-youtube-client-id.apps.googleusercontent.com"
YOUTUBE_CLIENT_SECRET="your-youtube-client-secret"
YOUTUBE_REDIRECT_URI="http://localhost:3001/auth/youtube/callback"

# ---------------------------------------------------------------------------
# OAuth — Facebook Pages
# Use the same Meta app as Threads/Instagram — add the "Manage everything
# on your Page" use case which grants pages_manage_posts + pages_show_list.
# Add a Facebook Login for Business product and set the redirect URI.
# ---------------------------------------------------------------------------
FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"
FACEBOOK_REDIRECT_URI="https://your-domain.com/auth/facebook/callback"

# ---------------------------------------------------------------------------
# OAuth — Pinterest
# Create an app at developers.pinterest.com
# Enable scopes: boards:read, boards:write, pins:read, pins:write, user_accounts:read
# Submit for review to allow users other than yourself to connect
# ---------------------------------------------------------------------------
PINTEREST_CLIENT_ID="your-pinterest-app-id"
PINTEREST_CLIENT_SECRET="your-pinterest-app-secret"
PINTEREST_REDIRECT_URI="https://your-domain.com/auth/pinterest/callback"
# Set to "true" while your app has Trial access (uses api-sandbox.pinterest.com).
# Remove or set to "false" once Pinterest grants you Standard access.
PINTEREST_SANDBOX=false
# Paste the sandbox access token from developers.pinterest.com → My Apps → Manage → Generate Access Token → Sandbox.
# Only used when PINTEREST_SANDBOX=true. Leave empty to use the OAuth token from the database.
PINTEREST_SANDBOX_TOKEN=""

# ---------------------------------------------------------------------------
# OAuth — X / Twitter (Pro & Team plans only)
# Create an app at developer.x.com (Free tier: 1,500 tweets/month shared).
# Under "User authentication settings" enable OAuth 1.0a with Read+Write.
# Set the callback URL to: https://your-domain.com/auth/twitter/callback
# ---------------------------------------------------------------------------
X_API_KEY="your-x-api-key"
X_API_SECRET="your-x-api-secret"
X_CALLBACK_URL="https://your-domain.com/auth/twitter/callback"

# ---------------------------------------------------------------------------
# Dodo Payments (only when ENABLE_BILLING=true)
# https://dodopayments.com
# ---------------------------------------------------------------------------
DODO_ENV="test_mode"
DODO_API_KEY="your-dodo-api-key"
DODO_WEBHOOK_SECRET="your-dodo-webhook-secret"
DODO_PRODUCT_CREATOR="your-creator-product-id"
DODO_PRODUCT_PRO="your-pro-product-id"
DODO_PRODUCT_TEAM="your-team-product-id"

# ---------------------------------------------------------------------------
# Discord (OAuth + Bot)
# 1. Create an app at https://discord.com/developers/applications
# 2. Add a bot, copy the bot token
# 3. Under OAuth2 > General, add redirect URI: https://your-domain.com/auth/discord/callback
# ---------------------------------------------------------------------------
DISCORD_CLIENT_ID="your-discord-client-id"
DISCORD_CLIENT_SECRET="your-discord-client-secret"
DISCORD_BOT_TOKEN="your-discord-bot-token"
DISCORD_REDIRECT_URI="https://your-domain.com/auth/discord/callback"
