PORT=3001
DATABASE_URL="file:./dev.db"

# Set to "true" to enable Dodo Payments billing and plan limits.
# Leave unset or "false" for self-hosted use — all features unlocked, no limits.
ENABLE_BILLING=false

# Auth provider — "local" (default, no extra setup) or "supabase" (cloud)
AUTH_PROVIDER=local

# JWT secrets — generate two separate random strings (local auth only)
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET="your-access-secret-here"
JWT_REFRESH_SECRET="your-refresh-secret-here"

# Web app URL — used for CORS and OAuth redirects
WEB_URL=http://localhost:3000

# Supabase (only required when AUTH_PROVIDER=supabase)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your-64-char-hex-key-here"

# Redis connection string — Upstash or Railway Redis
REDIS_URL="rediss://..."

# Threads OAuth — create an app at developers.facebook.com
THREADS_APP_ID="your-threads-app-id"
THREADS_APP_SECRET="your-threads-app-secret"
THREADS_REDIRECT_URI="https://your-domain.com/auth/threads/callback"

# Instagram OAuth — add Instagram product to your Meta app at developers.facebook.com
INSTAGRAM_APP_ID="your-instagram-app-id"
INSTAGRAM_APP_SECRET="your-instagram-app-secret"
INSTAGRAM_REDIRECT_URI="https://your-domain.com/auth/instagram/callback"

# Public HTTPS URL of this API — used by Meta to fetch images you upload
# Must be publicly reachable (not localhost). Use a tunnel in dev.
PUBLIC_API_URL="https://your-domain.com"

# LinkedIn OAuth — create an app at https://developer.linkedin.com
# Required products: "Share on LinkedIn" + "Sign In with LinkedIn using OpenID Connect"
LINKEDIN_CLIENT_ID="your-linkedin-client-id"
LINKEDIN_CLIENT_SECRET="your-linkedin-client-secret"
LINKEDIN_REDIRECT_URI="https://your-domain.com/auth/linkedin/callback"

# Dodo Payments — https://dodopayments.com
# DODO_ENV: "test_mode" for testing, "live_mode" for production
DODO_ENV="test_mode"
DODO_API_KEY="your-dodo-api-key"
DODO_WEBHOOK_SECRET="your-dodo-webhook-secret"
DODO_PRODUCT_CREATOR="your-creator-product-id"
DODO_PRODUCT_PRO="your-pro-product-id"
DODO_PRODUCT_TEAM="your-team-product-id"
