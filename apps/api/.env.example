PORT=3001
DATABASE_URL="file:./dev.db"

# Set to "true" to enable Dodo Payments billing and plan limits.
# Leave unset or "false" for self-hosted use — all features unlocked, no limits.
ENABLE_BILLING=false

# Auth provider — "local" (default, no extra setup) or "supabase" (cloud)
AUTH_PROVIDER=local

# JWT secrets — generate two separate random strings (local auth only)
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET="your-access-secret-here"
JWT_REFRESH_SECRET="your-refresh-secret-here"

# Web app URL — used for CORS and OAuth redirects
WEB_URL=http://localhost:3000

# Set to "true" in production so auth cookies are sent over HTTPS only
SECURE_COOKIES=false

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: never change this after accounts are saved — credentials become unreadable
ENCRYPTION_KEY="your-64-char-hex-key-here"

# Redis connection string — Upstash or Railway Redis
REDIS_URL="rediss://..."

# ---------------------------------------------------------------------------
# Storage — where uploaded media files are stored
# ---------------------------------------------------------------------------
# "local" (default) stores files on disk under apps/api/uploads/
# "supabase" uploads to Supabase Storage (required for production / multi-instance)
STORAGE_PROVIDER=local

# Supabase Storage (only when STORAGE_PROVIDER=supabase)
# Create a public bucket in the Supabase dashboard first
SUPABASE_STORAGE_BUCKET="media"

# ---------------------------------------------------------------------------
# Supabase (only required when AUTH_PROVIDER=supabase or STORAGE_PROVIDER=supabase)
# ---------------------------------------------------------------------------
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ---------------------------------------------------------------------------
# Email (password reset) — Resend (https://resend.com)
# Optional — falls back to console logging in dev if not set
# ---------------------------------------------------------------------------
RESEND_API_KEY="re_..."
# From address — must be from a domain verified in your Resend account
EMAIL_FROM="Posthive <noreply@yourdomain.com>"

# ---------------------------------------------------------------------------
# OAuth — Threads
# Create an app at developers.facebook.com and add the Threads use case
# ---------------------------------------------------------------------------
THREADS_APP_ID="your-threads-app-id"
THREADS_APP_SECRET="your-threads-app-secret"
THREADS_REDIRECT_URI="https://your-domain.com/auth/threads/callback"

# ---------------------------------------------------------------------------
# OAuth — Instagram
# Add the Instagram product to your Meta app at developers.facebook.com
# Requires a Professional (Business or Creator) Instagram account
# ---------------------------------------------------------------------------
INSTAGRAM_APP_ID="your-instagram-app-id"
INSTAGRAM_APP_SECRET="your-instagram-app-secret"
INSTAGRAM_REDIRECT_URI="https://your-domain.com/auth/instagram/callback"

# Public HTTPS URL of this API — Meta fetches uploaded images from here
# Must be publicly reachable (not localhost). Use a tunnel in dev.
PUBLIC_API_URL="https://your-domain.com"

# ---------------------------------------------------------------------------
# OAuth — LinkedIn
# Create an app at developer.linkedin.com
# Required products: "Share on LinkedIn" + "Sign In with LinkedIn using OpenID Connect"
# ---------------------------------------------------------------------------
LINKEDIN_CLIENT_ID="your-linkedin-client-id"
LINKEDIN_CLIENT_SECRET="your-linkedin-client-secret"
LINKEDIN_REDIRECT_URI="https://your-domain.com/auth/linkedin/callback"

# ---------------------------------------------------------------------------
# Mastodon OAuth
# Create an app at https://your-instance/settings/applications
# ---------------------------------------------------------------------------
MASTODON_CLIENT_ID="your-mastodon-client-id"
MASTODON_CLIENT_SECRET="your-mastodon-client-secret"
MASTODON_REDIRECT_URI="https://your-domain.com/auth/mastodon/callback"

# ---------------------------------------------------------------------------
# Dodo Payments (only when ENABLE_BILLING=true)
# https://dodopayments.com
# ---------------------------------------------------------------------------
DODO_ENV="test_mode"
DODO_API_KEY="your-dodo-api-key"
DODO_WEBHOOK_SECRET="your-dodo-webhook-secret"
DODO_PRODUCT_CREATOR="your-creator-product-id"
DODO_PRODUCT_PRO="your-pro-product-id"
DODO_PRODUCT_TEAM="your-team-product-id"
