  "homepage": "https://posthive.co/for-developers",
  "repository": {
    "type": "git",
    "url": "https://github.com/AstaBlackClove/posthive"
  },
  "bugs": {
    "url": "https://github.com/AstaBlackClove/posthive/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "@types/node": "^20.14.12"
  },
  "engines": {
    "node": ">=20"
  }
