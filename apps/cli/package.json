{
  "name": "posthive-cli",
  "version": "0.1.2",
  "description": "Posthive CLI — schedule posts to 11 social platforms from the command line or any AI agent (Claude Code, OpenClaw, Cursor)",
  "type": "module",
  "bin": {
    "posthive": "./dist/index.js"
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "posthive",
    "cli",
    "social-media",
    "scheduler",
    "ai-agent",
    "skill",
    "claude",
    "openclaw",
    "bluesky",
    "threads",
    "linkedin",
    "instagram",
    "mastodon"
  ],
  "author": "Posthive",
  "license": "AGPL-3.0",
  "homepage": "https://posthive.co/for-developers",
  "repository": {
    "type": "git",
    "url": "https://github.com/AstaBlackClove/posthive"
  },
  "bugs": {
    "url": "https://github.com/AstaBlackClove/posthive/issues"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "@types/node": "^20.14.12"
  },
  "engines": {
    "node": ">=20"
  }
}
